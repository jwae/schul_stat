# Docker-/Server-Betrieb mit docker compose
NODE_ENV=production
PORT=3000

DB_HOST=mariadb
DB_PORT=3306
DB_NAME=stats
DB_USER=stats_user
DB_PASSWORD=stats_password
DB_AUTO_CONNECT=true

MYSQL_DATABASE=stats
MYSQL_USER=stats_user
MYSQL_PASSWORD=stats_password
MYSQL_ROOT_PASSWORD=root_password

JWT_SECRET=change-this-before-production
JWT_EXPIRES_IN=8h
